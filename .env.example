# Database (PostgreSQL via Neon - get free at neon.tech)
DATABASE_URL="postgres://username:password@ep-example.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="https://your-domain.vercel.app"

# AI (Groq - get free key at console.groq.com)
GROQ_API_KEY="gsk_your_groq_api_key"
GROQ_MODEL="llama-3.3-70b-versatile"

# Email (Gmail App Password)
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-gmail-app-password"

# Razorpay (get keys at dashboard.razorpay.com)
RAZORPAY_KEY_ID="rzp_live_your_key_id"
RAZORPAY_KEY_SECRET="your_key_secret"
